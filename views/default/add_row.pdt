        <?php
        $this->Widget->clear();
        $this->Widget->setLinkButtons([
            [
                'name' => $this->_('Logicboxes.back_to_manage', true),
                'icon' => 'bi bi-arrow-left me-1',
                'attributes' => ['href' => $this->base_uri . 'settings/company/modules/manage/' . $module->id],
            ],
        ]);
        $this->Widget->create($this->_('Logicboxes.add_row.box_title', true));

        $this->Form->create(null, ['class' => 'disable-on-submit']);
        ?>

        <h6 class="form-section-header"><?php $this->_('Logicboxes.add_row.basic_title'); ?></h6>
        <div class="mb-3">
            <label for="registrar" class="form-label">
                <?php $this->_('Logicboxes.row_meta.registrar'); ?>
            </label>
            <?php $this->Form->fieldText('registrar', $vars->registrar ?? null, [
                'id' => 'registrar',
                'class' => 'form-control',
            ]); ?>
        </div>

        <div class="mb-3">
            <label for="reseller_id" class="form-label">
                <?php $this->_('Logicboxes.row_meta.reseller_id'); ?>
            </label>
            <?php $this->Form->fieldText('reseller_id', $vars->reseller_id ?? null, [
                'id' => 'reseller_id',
                'class' => 'form-control',
            ]); ?>
        </div>

        <div class="mb-3">
            <label for="key" class="form-label">
                <?php $this->_('Logicboxes.row_meta.key'); ?>
            </label>
            <?php $this->Form->fieldText('key', $vars->key ?? null, [
                'id' => 'key',
                'class' => 'form-control',
            ]); ?>
        </div>

        <div class="mb-3">
            <div class="form-check">
                <?php $this->Form->fieldCheckbox(
                    'sandbox',
                    'true',
                    ($vars->sandbox ?? null) == 'true',
                    ['id' => 'sandbox', 'class' => 'form-check-input'],
                ); ?>
                <label for="sandbox" class="form-check-label">
                    <?php $this->_('Logicboxes.row_meta.sandbox'); ?>
                </label>
                <i class="bi bi-info-circle ms-1"
                   data-bs-toggle="tooltip"
                   data-bs-placement="top"
                   title="<?php echo $this->Html->safe($this->_('Logicboxes.!tooltip.row_meta.sandbox', true));?>"></i>
            </div>
        </div>

        <?php $this->Widget->footer(); ?>
        <div class="d-flex justify-content-end">
            <?php $this->Form->fieldSubmit('save', $this->_('Logicboxes.add_row.add_btn', true), ['class' => 'btn btn-primary']); ?>
        </div>

        <?php
        $this->Form->end();
        $this->Widget->end();

        // Initialize tooltips
        $this->Javascript->setInline('
document.addEventListener("DOMContentLoaded", function() {
    const tooltipTriggerList = document.querySelectorAll(\'[data-bs-toggle="tooltip"]\');
    [...tooltipTriggerList].map(function(tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});
');
        ?>
