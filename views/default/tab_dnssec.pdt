<div id="ds-records">
    <div class="alert alert-warning d-flex align-items-start" role="alert">
        <i class="bi bi-exclamation-triangle me-2 mt-1"></i>
        <div>
            <p class="mb-1"><?php $this->_('Logicboxes.tab_dnssec.warning_message1'); ?></p>
            <p class="mb-0"><?php $this->_('Logicboxes.tab_dnssec.warning_message2'); ?></p>
        </div>
    </div>

    <h6 class="form-section-header"><?php $this->_('Logicboxes.tab_dnssec.title'); ?></h6>
    <?php if (count($records ?? []) > 0) { ?>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th><?php $this->_('Logicboxes.tab_dnssec.keytag'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnssec.algorithm'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnssec.digesttype'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnssec.digest'); ?></th>
                        <th class="text-end"><?php $this->_('Logicboxes.tab_dnssec.field_delete'); ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($records as $i => $record) { ?>
                        <tr>
                            <td><?php echo $this->Html->safe($record->keytag ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->algorithm ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->digesttype ?? null); ?></td>
                            <td style="word-wrap:break-word; overflow-wrap: break-word; word-break: break-word;"><?php echo $this->Html->safe(
                                $record->digest ?? null,
                            ); ?></td>
                            <td class="text-end">
                                <?php
                                $this->Form->create();
                                $this->Form->fieldHidden('keytag', $record->keytag ?? null);
                                $this->Form->fieldHidden('algorithm', $record->algorithm ?? null);
                                $this->Form->fieldHidden('digesttype', $record->digesttype ?? null);
                                $this->Form->fieldHidden('digest', $record->digest ?? null);

                                $button_attributes = [
                                    'class' => 'btn btn-sm btn-outline-danger',
                                    'value' => 'deleteDsRecord',
                                    'type' => 'submit',
                                ];

                                $this->Form->fieldButton(
                                    'action',
                                    '<i class="bi bi-trash"></i>',
                                    $button_attributes,
                                );

                                $this->Form->end();
                                ?>
                            </td>
                        </tr>
                    <?php } ?>
                </tbody>
            </table>
        </div>
    <?php } else { ?>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
            <p class="mt-3 mb-0"><?php $this->_('Logicboxes.tab_dnssec.no_records'); ?></p>
        </div>
    <?php } ?>

    <h6 class="form-section-header mt-4"><?php $this->_('Logicboxes.tab_dnssec.title_add'); ?></h6>
    <?php
$this->Form->create();
?>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th><?php $this->_('Logicboxes.tab_dnssec.keytag'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnssec.algorithm'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnssec.digesttype'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnssec.digest'); ?></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><?php $this->Form->fieldNumber('keytag', null, 0, 65536, 1, [
                            'class' => 'form-control form-control-sm',
                        ]); ?></td>
                        <td><?php $this->Form->fieldSelect('algorithm', $algorithms ?? [], null, [
                            'class' => 'form-select',
                        ]); ?></td>
                        <td><?php $this->Form->fieldSelect('digesttype', $digests ?? [], null, [
                            'class' => 'form-select',
                        ]); ?></td>
                        <td><?php $this->Form->fieldText('digest', null, ['class' => 'form-control']); ?></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-primary" type="submit" name="action" value="addDsRecord">
                                <i class="bi bi-plus-lg"></i> <?php $this->_('Logicboxes.tab_dnssec.field_add'); ?>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    <?php $this->Form->end(); ?>
</div>
