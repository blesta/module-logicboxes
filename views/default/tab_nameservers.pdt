
    <?php
$this->Form->create();
?>
        <div class="row g-3">
            <?php for ($i = 0; $i < 5; $i++) { ?>
            <div class="col-md-6">
                <?php
                $this->Form->label($this->_('Logicboxes.tab_nameserver.field_ns', true, $i + 1), 'ns' . ($i + 1), ['class' => 'form-label']);
                $this->Form->fieldText('ns[]', isset($vars->ns[$i]) ? $vars->ns[$i] : null, [
                    'id' => 'ns' . ($i + 1),
                    'class' => 'form-control',
                ]);
                ?>
            </div>
            <?php } ?>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-3">
            <?php $this->Form->fieldSubmit('save', $this->_('Logicboxes.tab_nameservers.field_submit', true), [
                'class' => 'btn btn-primary',
            ]); ?>
        </div>
    <?php
$this->Form->end();
?>
