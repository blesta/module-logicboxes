
    <?php
    $this->Form->create();
    foreach ($fields as $field) {
        if ($field->type == 'fieldHidden') {
            call_user_func_array([$this->Form, $field->type], $field->params);
        }
    }
    ?>

    <?php
    $i = 0;
    foreach ($sections as $key) { ?>
    <h6 class="form-section-header<?php echo $i == 0 ? ' mt-0' : ''; ?>"><?php $this->_('Logicboxes.tab_whois.section_' . $key); ?></h6>
    <div class="row g-3">
        <?php foreach ($fields as $field) {
            if ($field->type != 'label' || substr($field->params['for'], 0, strlen($key)) != $key) {
                continue;
            }
        ?>
        <div class="col-md-6">
            <?php
            // Draw the primary label/field
            $label_params = $field->params;
            if (isset($label_params['attributes']['class'])) {
                if (is_array($label_params['attributes']['class'])) {
                    $label_params['attributes']['class'][] = 'form-label';
                } else {
                    $label_params['attributes']['class'] .= ' form-label';
                }
            } else {
                $label_params['attributes']['class'] = 'form-label';
            }
            $field->params = $label_params;
            call_user_func_array([$this->Form, $field->type], $field->params);

            // Draw each form field associated with this label
            $tooltips = [];
            foreach ($field->fields as $input) {
                // Collect all tooltips to be displayed at the end
                if ($input->type == 'tooltip') {
                    $tooltips[] = $input;
                    continue;
                }

                // Add form-control class to input fields if applicable
                if (in_array($input->type, ['fieldText', 'fieldTextarea', 'fieldSelect', 'fieldPassword'])) {
                    if (isset($input->params['attributes']['class'])) {
                        if (is_array($input->params['attributes']['class'])) {
                            $input->params['attributes']['class'][] = 'form-control';
                        } else {
                            $input->params['attributes']['class'] .= ' form-control';
                        }
                    } else {
                        $input->params['attributes']['class'] = 'form-control';
                    }
                }

                call_user_func_array([$this->Form, $input->type], $input->params);

                // Draw the form field's secondary label if checkbox or radio item
                if (($input->type == 'fieldCheckbox' || $input->type == 'fieldRadio') && isset($input->label)) {
                    if (isset($input->label->params['attributes']['class'])) {
                        if (is_array($input->label->params['attributes']['class'])) {
                            $input->label->params['attributes']['class'][] = 'form-check-label';
                        } else {
                            $input->label->params['attributes']['class'] .= ' form-check-label';
                        }
                    } else {
                        $input->label->params['attributes']['class'] = 'form-check-label';
                    }

                    call_user_func_array([$this->Form, 'label'], $input->label->params);
                }
            }

            foreach ($tooltips as $tooltip) {
                $message = isset($tooltip->params['message'])
                    ? $this->Html->safe($tooltip->params['message'])
                    : null;
            ?>
                <i class="bi bi-info-circle ms-1"
                   data-bs-toggle="tooltip"
                   data-bs-placement="top"
                   title="<?php echo $message; ?>"></i>
            <?php }
            ?>
        </div>
        <?php
        } ?>
    </div>
    <?php $i++;}
    ?>

    <div class="d-flex gap-2 justify-content-end mt-3">
        <?php $this->Form->fieldSubmit('save', $this->_('Logicboxes.tab_whois.field_submit', true), [
            'class' => 'btn btn-primary',
        ]); ?>
    </div>
    <?php $this->Form->end();

    // Initialize tooltips
    $this->Javascript->setInline('
document.addEventListener("DOMContentLoaded", function() {
    const tooltipTriggerList = document.querySelectorAll(\'[data-bs-toggle="tooltip"]\');
    [...tooltipTriggerList].map(function(tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});
');
?>
