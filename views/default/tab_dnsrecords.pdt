<div id="dns-records">
    <h6 class="form-section-header"><?php $this->_('Logicboxes.tab_dnsrecord.title'); ?></h6>
    <p class="text-muted mb-3"><?php $this->_('Logicboxes.tab_dnsrecord.help_text'); ?></p>

    <?php if (count($records ?? []) > 0) { ?>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.record_type'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.host'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.value'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.ttl'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.priority'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.port'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.weight'); ?></th>
                        <th class="text-end"><?php $this->_('Logicboxes.tab_dnsrecord.field_delete'); ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($records as $i => $record) { ?>
                        <tr>
                            <td><?php echo $this->Html->safe($record->type ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->host ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->value ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->timetolive ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->priority ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->port ?? null); ?></td>
                            <td><?php echo $this->Html->safe($record->weight ?? null); ?></td>
                            <td class="text-end">
                                <?php
                                $this->Form->create();
                                $this->Form->fieldHidden('type', $record->type ?? null);
                                $this->Form->fieldHidden('host', $record->host ?? null);
                                $this->Form->fieldHidden('value', $record->value ?? null);
                                $this->Form->fieldHidden('priority', $record->priority ?? null);
                                $this->Form->fieldHidden('port', $record->port ?? null);
                                $this->Form->fieldHidden('weight', $record->weight ?? null);

                                $button_attributes = [
                                    'class' => 'btn btn-sm btn-outline-danger',
                                    'value' => 'deleteDnsRecord',
                                    'type' => 'submit',
                                ];

                                $this->Form->fieldButton(
                                    'action',
                                    '<i class="bi bi-trash"></i>',
                                    $button_attributes,
                                );

                                $this->Form->end();
                                ?>
                            </td>
                        </tr>
                    <?php } ?>
                </tbody>
            </table>
        </div>
    <?php } else { ?>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
            <p class="mt-3 mb-0"><?php $this->_('Logicboxes.tab_dnsrecord.no_records'); ?></p>
        </div>
    <?php } ?>

    <h6 class="form-section-header mt-4"><?php $this->_('Logicboxes.tab_dnsrecord.title_add'); ?></h6>
    <?php $this->Form->create(); ?>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.record_type'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.host'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.value'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.ttl'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.priority'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.port'); ?></th>
                        <th><?php $this->_('Logicboxes.tab_dnsrecord.weight'); ?></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><?php $this->Form->fieldSelect('type', $types ?? [], null, [
                            'class' => 'form-select form-select-sm',
                        ]); ?></td>
                        <td><?php $this->Form->fieldText('host', null, ['class' => 'form-control']); ?></td>
                        <td><?php $this->Form->fieldText('value', null, ['class' => 'form-control']); ?></td>
                        <td><?php $this->Form->fieldNumber('ttl', null, null, null, null, [
                            'class' => 'form-control form-control-sm',
                        ]); ?></td>
                        <td><?php $this->Form->fieldNumber('priority', null, null, null, null, [
                            'class' => 'form-control form-control-sm',
                            'id' => 'priority',
                            'disabled' => '',
                        ]); ?></td>
                        <td><?php $this->Form->fieldNumber('port', null, 0, 65535, 1, [
                            'class' => 'form-control form-control-sm',
                            'id' => 'port',
                            'disabled' => '',
                        ]); ?></td>
                        <td><?php $this->Form->fieldNumber('weight', null, null, null, null, [
                            'class' => 'form-control form-control-sm',
                            'id' => 'weight',
                            'disabled' => '',
                        ]); ?></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-primary" type="submit" name="action" value="addDnsRecord">
                                <i class="bi bi-plus-lg"></i> <?php $this->_('Logicboxes.tab_dnsrecord.field_add'); ?>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    <?php $this->Form->end(); ?>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const typeSelect = document.querySelector('[name="type"]');
    const priorityField = document.getElementById('priority');
    const portField = document.getElementById('port');
    const weightField = document.getElementById('weight');

    if (typeSelect) {
        typeSelect.addEventListener('change', function() {
            const value = this.value;
            if (value == 'MX') {
                priorityField.disabled = false;
                portField.disabled = true;
                weightField.disabled = true;
            } else if (value == 'SRV') {
                priorityField.disabled = false;
                portField.disabled = false;
                weightField.disabled = false;
            } else {
                priorityField.disabled = true;
                portField.disabled = true;
                weightField.disabled = true;
            }
        });
    }
});
</script>
